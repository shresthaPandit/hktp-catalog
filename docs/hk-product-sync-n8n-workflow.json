      "id": "11111111-0000-0000-0000-000000000014",
      "name": "HTTP: Get Product Detail",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        2720,
        320
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const BASE_IMG_URL = 'https://hkmis.ca/web/product-images/';\nconst staticData = $getWorkflowStaticData('global');\nconst products = [];\n\nfor (const item of $input.all()) {\n  if (item.json.status !== 'success' || !item.json.products) {\n    staticData.totalFailed = (staticData.totalFailed || 0) + 1;\n    continue;\n  }\n\n  const p = item.json.products;\n\n  const priceRaw = parseFloat((p.selling_price || '0').replace(/,/g, ''));\n  const price = priceRaw > 0 ? priceRaw : null;\n\n  const qty = parseFloat(p.current_qty || '0');\n  const in_stock = qty > 0;\n\n  const rawImages = Array.isArray(p.images) ? p.images : (p.image ? [p.image] : []);\n  const image_urls = rawImages.filter(Boolean).map(img => BASE_IMG_URL + img);\n  const primary_image_url = image_urls[0] || null;\n\n  const category = (p.category || '').split(',')[0].trim() || null;\n  const brand = p.brands || null;\n\n  products.push({\n    external_id: String(p.id),\n    sku: p.sku,\n    name: p.name || null,\n    description: (p.description || '').replace(/\\r\\n/g, '\\n').trim() || null,\n    category,\n    subcategory: null,\n    brand,\n    price,\n    image_urls,\n    primary_image_url,\n    specifications: {},\n    alternate_skus: Array.isArray(p.cross_refs)\n      ? p.cross_refs\n          .map(s => typeof s === 'string' && s.includes('\t') ? s.split('\t').pop() : s)\n          .map(s => (s || '').replace(/[,;]+$/, '').trim())\n          .filter(Boolean)\n      : [],\n    related_parts: Array.isArray(p.related_products) ? p.related_products.map(Number).filter(n => n > 0) : [],\n    in_stock,\n    last_sync_at: new Date().toISOString()\n  });\n\n  staticData.totalSynced = (staticData.totalSynced || 0) + 1;\n}\n\n// Output as single item containing array \u00e2\u20ac\u201d sent as one bulk upsert to Supabase\nreturn [{ json: { products } }];"
      },
