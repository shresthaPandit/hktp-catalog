        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst allItems = $input.all();\n\n// Read current count from HTTP: Get Count response\nlet currentCount = 0;\nfor (const item of allItems) {\n  const data = Array.isArray(item.json) ? item.json[0] : item.json;\n  if (data?.count !== undefined) {\n    currentCount = Number(data.count) || 0;\n    break;\n  }\n}\n\nstaticData.currentCount = currentCount;\n\n// Always sync \u00e2\u20ac\u201d count-change guard removed. Runs 2x daily, handles new/deleted SKUs.\nreturn [{ json: { shouldSync: true, currentCount, isManual: !!staticData.isManual } }];"
      },
