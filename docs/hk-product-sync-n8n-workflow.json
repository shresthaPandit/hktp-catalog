    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\n// Supabase REST returns array; handle both array and direct object\nconst raw = $input.first().json;\nconst record = Array.isArray(raw) ? raw[0] : raw;\nstaticData.currentSyncLogId = record?.id;\n\n// Read count directly from Code: Should We Sync output \u00e2\u20ac\u201d more reliable than staticData\nlet count = 0;\ntry {\n  count = $('Code: Should We Sync').first().json.currentCount || 0;\n} catch(e) {\n  count = staticData.currentCount || 0;\n}\n\nconst limit = 1000;\nconst offsets = [];\nfor (let offset = 0; offset < count; offset += limit) {\n  offsets.push({ json: { offset, limit } });\n}\n\nif (offsets.length === 0) offsets.push({ json: { offset: 0, limit } });\n\nreturn offsets;"
      },
